{
  "Debug": true,
  "ListenAddress": ":3000",
  "MySQLTopologyUser": "orchestrator",
  "MySQLTopologyPassword": "orch_pass",
  "MySQLTopologySSLMode": "skip-verify",
  "MySQLOrchestratorHost": "orchestrator-db",
  "MySQLOrchestratorPort": 3306,
  "MySQLOrchestratorDatabase": "orchestrator",
  "MySQLOrchestratorUser": "orchestrator",
  "MySQLOrchestratorPassword": "orch_db_pass",
  "InstancePollSeconds": 5,
  "DiscoverByShowSlaveHosts": true,
  "RecoveryPeriodBlockSeconds": 60,
  "RecoverMasterClusterFilters": ["*"],
  "MySQLHostnameResolveMethod": "none",
  "DetectionPollSeconds": 3,
  "InstanceBulkOperationsWaitTimeout": 10,
  "ActiveNodeExpireSeconds": 60,
  "AvoidActiveNodeAutoReelections": true,
  "PostFailoverProcesses": [
    "curl -sS -X POST http://openclaw:18789/hooks/agent -H 'Content-Type: application/json' -H 'Authorization: Bearer clawsql-webhook-secret' -d '{\"skill\":\"mysql-failover\"}'"
  ]
}
