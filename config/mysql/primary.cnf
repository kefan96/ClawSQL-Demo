[mysqld]
server-id                      = 100
port                           = 3306
log_bin                        = mysql-bin
binlog_format                  = ROW
binlog_row_image               = FULL
gtid_mode                      = ON
enforce_gtid_consistency       = ON
log_slave_updates              = ON
relay_log                      = relay-bin
relay_log_recovery             = ON
read_only                      = 0
super_read_only                = 0
report_host                    = mysql-primary
report_port                    = 3306
innodb_buffer_pool_size        = 128M
innodb_flush_log_at_trx_commit = 1
sync_binlog                    = 1
