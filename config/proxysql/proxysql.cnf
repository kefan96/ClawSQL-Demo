datadir="/var/lib/proxysql"

admin_variables=
{
  admin_credentials="admin:admin_pass"
  mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
  threads=4
  max_connections=2048
  default_query_delay=0
  default_query_timeout=36000000
  interfaces="0.0.0.0:6033"
  default_schema="information_schema"
  server_version="8.0.35"
  monitor_username="proxysql_mon"
  monitor_password="mon_pass"
  monitor_connect_interval=60000
  monitor_ping_interval=10000
  monitor_read_only_interval=1500
  monitor_read_only_timeout=500
}

mysql_servers=
(
  { hostgroup_id=10, hostname="mysql-primary",   port=3306, weight=1000, max_connections=200 },
  { hostgroup_id=20, hostname="mysql-replica-1", port=3306, weight=1000, max_connections=200 },
  { hostgroup_id=20, hostname="mysql-replica-2", port=3306, weight=1000, max_connections=200 }
)

mysql_users=
(
  { username="app", password="app_pass", default_hostgroup=10, max_connections=500, active=1 }
)

mysql_query_rules=
(
  {
    rule_id=100
    active=1
    match_digest="^SELECT .* FOR UPDATE$"
    destination_hostgroup=10
    apply=1
    comment="SELECT FOR UPDATE -> writer"
  },
  {
    rule_id=200
    active=1
    match_digest="^SELECT"
    destination_hostgroup=20
    apply=1
    comment="SELECT -> reader"
  }
)
