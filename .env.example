# OpenClaw image (replace with your deployment)
OPENCLAW_IMAGE=openclaw/openclaw:latest

# =============================================================================
# AI Provider Configuration (choose ONE of the following options)
# =============================================================================

# Option 1: Anthropic API (default)
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Alibaba DashScope (Qwen models)
# Get your key from https://help.aliyun.com/zh/model-studio/
# Uncomment the following line and set your key to use Qwen instead of Anthropic
# DASHSCOPE_API_KEY=sk-...

# =============================================================================
# ClawSQL Cluster Configuration
# =============================================================================

# Cluster alias (used by all skills)
CLUSTER_ALIAS=clawsql-demo

# Orchestrator
ORCHESTRATOR_URL=http://orchestrator:3000

# ProxySQL Admin
PROXYSQL_HOST=proxysql
PROXYSQL_PORT=6032
PROXYSQL_USER=admin
PROXYSQL_PASSWORD=admin_pass

# MySQL root (for scripts only)
MYSQL_ROOT_PASSWORD=root_pass
