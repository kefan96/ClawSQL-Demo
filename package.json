{
  "name": "clawsql",
  "version": "1.0.0",
  "description": "ClawSQL - MySQL cluster management with AI-powered failover",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawsql": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cli": "tsx src/cli/index.ts",
    "shell": "tsx src/cli/index.ts shell",
    "serve": "tsx src/api/server.ts",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e --timeout 60000",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mysql",
    "failover",
    "replication",
    "proxysql",
    "high-availability",
    "orchestrator"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^12.0.0",
    "fastify": "^4.26.0",
    "mysql2": "^3.6.0",
    "openai": "^4.0.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.0",
    "ws": "^8.16.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
